<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.oa.system.mapper.SysDeptMapper">

    <resultMap id="SysDeptResult" type="com.oa.system.entity.SysDept">
        <id property="id" column="id"/>
        <result property="parentId" column="parent_id"/>
        <result property="ancestors" column="ancestors"/>
        <result property="deptName" column="dept_name"/>
        <result property="deptCode" column="dept_code"/>
        <result property="deptType" column="dept_type"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="leader" column="leader"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="status" column="status"/>
        <result property="parentName" column="parent_name"/>
    </resultMap>

    <select id="selectDeptTree" resultMap="SysDeptResult">
        SELECT d.*, p.dept_name as parent_name
        FROM sys_dept d
        LEFT JOIN sys_dept p ON d.parent_id = p.id
        WHERE d.del_flag = 0
        ORDER BY d.sort_order
    </select>

    <select id="selectChildrenDeptById" resultMap="SysDeptResult">
        SELECT * FROM sys_dept WHERE parent_id = #{parentId} AND del_flag = 0
        ORDER BY sort_order
    </select>

    <select id="countUserByDeptId" resultType="int">
        SELECT COUNT(*) FROM sys_user WHERE dept_id = #{deptId} AND del_flag = 0
    </select>

</mapper>