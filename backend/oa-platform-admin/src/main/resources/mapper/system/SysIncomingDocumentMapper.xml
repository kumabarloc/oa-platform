<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.oa.system.mapper.SysIncomingDocumentMapper">
    <select id="selectNextDocNumber" resultType="string">
        SELECT MAX(doc_number) FROM sys_incoming_document
        WHERE doc_number LIKE CONCAT('SW-', #{date}, '-%')
    </select>
</mapper>
