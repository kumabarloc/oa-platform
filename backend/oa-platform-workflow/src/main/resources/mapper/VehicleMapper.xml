<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.oa.workflow.mapper.VehicleMapper">

    <!-- 用车申请分页列表（不含 total，MP 自动处理） -->
    <select id="selectVehiclePage" resultType="com.oa.workflow.entity.SysVehicle">
        SELECT * FROM sys_vehicle
        WHERE del_flag = '0'
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        <if test="userId != null">
            AND draft_user_id = #{userId}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
