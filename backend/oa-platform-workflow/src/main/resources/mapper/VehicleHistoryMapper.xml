<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.oa.workflow.mapper.VehicleHistoryMapper">

    <!-- 查询用车申请历史记录 -->
    <select id="selectHistoryByVehicleId" resultType="com.oa.workflow.entity.SysVehicleHistory">
        SELECT * FROM sys_vehicle_history
        WHERE vehicle_id = #{vehicleId}
        ORDER BY start_time ASC
    </select>

</mapper>
