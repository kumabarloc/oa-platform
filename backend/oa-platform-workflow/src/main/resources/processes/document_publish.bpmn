<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://flowable.org/test">

    <!-- 流程定义 -->
    <process id="document_publish" name="公文发布流程" isExecutable="true">

        <!-- 开始事件 -->
        <startEvent id="start" name="起草完成"/>

        <!-- 部门负责人审批节点 -->
        <userTask id="dept_approval" name="部门负责人审批" flowable:assignee="${initiator}">
            <documentation>部门负责人审核公文内容</documentation>
        </userTask>

        <!-- 综合办公室审批节点 -->
        <userTask id="office_approval" name="综合办公室审批" flowable:assignee="${initiator}">
            <documentation>综合办公室复核并发布</documentation>
        </userTask>

        <!-- 结束事件 - 发布 -->
        <endEvent id="published" name="已发布"/>

        <!-- 流程连线 -->
        <sequenceFlow id="flow_submit" sourceRef="start" targetRef="dept_approval"
                      name="提交审核"/>
        <sequenceFlow id="flow_dept_pass" sourceRef="dept_approval" targetRef="office_approval"
                      name="部门通过"/>
        <sequenceFlow id="flow_dept_reject" sourceRef="dept_approval" targetRef="end_reject"
                      name="部门驳回"/>
        <sequenceFlow id="flow_office_pass" sourceRef="office_approval" targetRef="published"
                      name="办公室通过"/>
        <sequenceFlow id="flow_office_reject" sourceRef="office_approval" targetRef="end_reject"
                      name="办公室驳回"/>

        <!-- 结束事件 - 驳回 -->
        <endEvent id="end_reject" name="已驳回"/>

        <!-- 排他网关：部门审批结果路由 -->
        <exclusiveGateway id="dept_gateway" name="部门审批网关"/>
        <!-- 排他网关：办公室审批结果路由 -->
        <exclusiveGateway id="office_gateway" name="办公室审批网关"/>

        <!-- 连接网关 -->
        <sequenceFlow id="flow_dept_to_gateway" sourceRef="dept_approval" targetRef="dept_gateway"/>
        <sequenceFlow id="flow_gateway_to_office" sourceRef="dept_gateway" targetRef="office_approval">
            <conditionExpression xsi:type="tFormalExpression">${approved == true}</conditionExpression>
        </sequenceFlow>
        <sequenceFlow id="flow_gateway_to_reject" sourceRef="dept_gateway" targetRef="end_reject">
            <conditionExpression xsi:type="tFormalExpression">${approved == false}</conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flow_office_to_gateway" sourceRef="office_approval" targetRef="office_gateway"/>
        <sequenceFlow id="flow_office_gateway_to_publish" sourceRef="office_gateway" targetRef="published">
            <conditionExpression xsi:type="tFormalExpression">${approved == true}</conditionExpression>
        </sequenceFlow>
        <sequenceFlow id="flow_office_gateway_to_reject" sourceRef="office_gateway" targetRef="end_reject">
            <conditionExpression xsi:type="tFormalExpression">${approved == false}</conditionExpression>
        </sequenceFlow>

    </process>

    <!-- BPMN图形定义 -->
    <BPMNDiagram id="BPMNDiagram_document_publish">
        <BPMNPlane bpmnElement="document_publish">
        </BPMNPlane>
    </BPMNDiagram>
</definitions>
