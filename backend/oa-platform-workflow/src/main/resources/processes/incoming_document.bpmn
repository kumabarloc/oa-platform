<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://flowable.org/test">

    <!-- 收文审批流程定义 -->
    <process id="incoming_document" name="收文审批流程" isExecutable="true">

        <!-- 开始事件 -->
        <startEvent id="start" name="收到来文"/>

        <!-- 领导审批节点（支持会签） -->
        <userTask id="leader_approval" name="领导审批" flowable:assignee="${initiator}">
            <documentation>领导审核收文内容</documentation>
            <multiInstanceLoopCharacteristics isSequential="false">
                <loopCardinality>1</loopCardinality>
                <completionCondition>${nrOfCompletedInstances >= 1}</completionCondition>
            </multiInstanceLoopCharacteristics>
        </userTask>

        <!-- 办公室审批节点（支持会签） -->
        <userTask id="office_approval" name="办公室审批" flowable:assignee="${initiator}">
            <documentation>办公室复核并分发</documentation>
            <multiInstanceLoopCharacteristics isSequential="false">
                <loopCardinality>1</loopCardinality>
                <completionCondition>${nrOfCompletedInstances >= 1}</completionCondition>
            </multiInstanceLoopCharacteristics>
        </userTask>

        <!-- 结束事件 - 审批完成 -->
        <endEvent id="approved" name="已审批"/>

        <!-- 结束事件 - 驳回 -->
        <endEvent id="rejected" name="已驳回"/>

        <!-- 排他网关 -->
        <exclusiveGateway id="leader_gateway" name="领导审批网关"/>
        <exclusiveGateway id="office_gateway" name="办公室审批网关"/>

        <!-- 流程连线 -->
        <sequenceFlow id="flow_start_to_leader" sourceRef="start" targetRef="leader_approval" name="提交审批"/>
        <sequenceFlow id="flow_leader_to_gateway" sourceRef="leader_approval" targetRef="leader_gateway"/>
        <sequenceFlow id="flow_leader_pass" sourceRef="leader_gateway" targetRef="office_approval">
            <conditionExpression xsi:type="tFormalExpression">${approved == true}</conditionExpression>
        </sequenceFlow>
        <sequenceFlow id="flow_leader_reject" sourceRef="leader_gateway" targetRef="rejected">
            <conditionExpression xsi:type="tFormalExpression">${approved == false}</conditionExpression>
        </sequenceFlow>
        <sequenceFlow id="flow_office_to_gateway" sourceRef="office_approval" targetRef="office_gateway"/>
        <sequenceFlow id="flow_office_pass" sourceRef="office_gateway" targetRef="approved">
            <conditionExpression xsi:type="tFormalExpression">${approved == true}</conditionExpression>
        </sequenceFlow>
        <sequenceFlow id="flow_office_reject" sourceRef="office_gateway" targetRef="rejected">
            <conditionExpression xsi:type="tFormalExpression">${approved == false}</conditionExpression>
        </sequenceFlow>

    </process>

    <!-- BPMN图形定义 -->
    <BPMNDiagram id="BPMNDiagram_incoming_document">
        <BPMNPlane bpmnElement="incoming_document">
        </BPMNPlane>
    </BPMNDiagram>
</definitions>
